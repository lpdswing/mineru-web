# Worker 配置
WORKER_REPLICAS=1
WORKER_CONCURRENCY=1

# MinIO 配置：填写浏览器和容器都能访问的宿主机 IP/域名
MINIO_ENDPOINT=SERVER_IP:9000

# MinerU API 调用方式：0 使用同步 /file_parse，1 使用 /tasks 提交和轮询
MINERU_API_USE_ASYNC_TASKS=0

# 仅在使用 vlm-http-client / hybrid-http-client 并接入外部 OpenAI 兼容服务时配置
# SERVER_URL=http://openai-compatible-server:30000

# MinerU-Popo 后处理：默认关闭
POPO_ENABLED=0
POPO_API_URL=http://popo-postprocessor:8010
POPO_TIMEOUT_SECONDS=1800
# Popo 容器访问 MinIO 的地址；使用内置 MinIO 时保持默认
POPO_MINIO_ENDPOINT=minio:9000
